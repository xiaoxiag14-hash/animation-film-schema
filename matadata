<body>
  <header class="hero">
    <div class="container hero-inner">
      <div class="hero-main">
        <div class="top-tag"><span class="dot">🌸</span> Final Metadata Schema Project</div>
        <h1>Animation Film<br>Metadata Schema</h1>
